    elif call.data == "General":
        message_layer(call, geometry_text, "Rectangle", '4 четырёхугольник.png')

    elif call.data == "Rectangle":
        message_layer(call, rectangle_text, "Rectangle", '4 прямоугольник.png')

    elif call.data == "Square":
